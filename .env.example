# Google Service Account
GOOGLE_SERVICE_ACCOUNT_JSON=safe/service_account.json

# Google Sheets
SHEETS_SPREADSHEET_ID=YOUR_SHEET_ID
SHEETS_WORKSHEET_NAME=?뚯떛紐⑸줉

# Discord Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL
MUSINSA_WEBHOOK=https://discord.com/api/webhooks/MUSINSA_WEBHOOK_URL
OLIVE_WEBHOOK=https://discord.com/api/webhooks/OLIVE_WEBHOOK_URL
GMARKET_WEBHOOK=https://discord.com/api/webhooks/GMARKET_WEBHOOK_URL
TWENTYNINE_WEBHOOK=https://discord.com/api/webhooks/TWENTYNINE_WEBHOOK_URL
AUCTION_WEBHOOK=https://discord.com/api/webhooks/AUCTION_WEBHOOK_URL
ELEVENST_WEBHOOK=https://discord.com/api/webhooks/ELEVENST_WEBHOOK_URL
COUPANG_ORDER_WEBHOOK=https://discord.com/api/webhooks/COUPANG_ORDER_WEBHOOK_URL

# Coupang Open API
COUPANG_ACCESS_KEY=your_access_key
COUPANG_SECRET_KEY=your_secret_key
COUPANG_VENDOR_ID=your_vendor_id
COUPANG_PRODUCT_SHEET=쿠팡상품관리
COUPANG_ORDER_SHEET=쿠팡주문관리
COUPANG_PRODUCT_REFRESH_MINUTES=30
# Runtime mode: full | sourcing_only
BOT_MODE=full

# MyMunja SMS
MYMUNJA_ID=your_id
MYMUNJA_PASS=your_pass
MYMUNJA_CALLBACK=諛쒖떊踰덊샇

# Optional runtime params
# MAX_CONCURRENCY=5
# PER_DOMAIN_CONCURRENCY=2
# DRY_RUN=false

# ── 상품 발굴 설정 ──
DISCOVERY_ENABLED=false
DISCOVERY_WEBHOOK=https://discord.com/api/webhooks/YOUR_DISCOVERY_WEBHOOK
DISCOVERY_DAILY_SUMMARY_HOUR=21

# 수집 설정
DISCOVERY_TOP_N=20
DISCOVERY_INTERVAL_MINUTES=30
DISCOVERY_CATEGORIES=스킨케어,메이크업,바디케어,헤어케어,향수,클렌징

# 마진 계산
DISCOVERY_DEFAULT_COMMISSION_RATE=10.8
DISCOVERY_SHIPPING_COST=3000
DISCOVERY_PACKING_COST=500
DISCOVERY_MIN_MARGIN_RATE=8.0
DISCOVERY_DEFAULT_MARKUP=1.35

# 스코어링 기준
DISCOVERY_S_GRADE_THRESHOLD=80
DISCOVERY_A_GRADE_THRESHOLD=60
DISCOVERY_B_GRADE_THRESHOLD=40

# Google Sheets 발굴상품 탭
DISCOVERY_SHEET_NAME=발굴상품
